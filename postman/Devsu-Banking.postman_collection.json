            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Account service disponible', () => pm.response.to.have.status(200));",
                  "pm.test('Estado UP', () => pm.expect(pm.response.json().status).to.eql('UP'));"
                ]
              }
            }
