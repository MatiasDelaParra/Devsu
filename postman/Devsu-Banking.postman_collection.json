    {
      "name": "4. Reporte",
      "item": [
        {
          "name": "Estado de cuenta de Marianela",
          "request": {
            "method": "GET",
            "url": "{{accountBaseUrl}}/api/reportes?fecha={{today}},{{today}}&cliente=CLI-MARIANELA"
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Reporte generado', () => pm.response.to.have.status(200));",
                "const report = pm.response.json();",
                "pm.test('Cliente correcto', () => pm.expect(report.cliente).to.eql('Marianela Montalvo'));",
                "pm.test('Incluye sus dos cuentas', () => pm.expect(report.cuentas).to.have.lengthOf(2));",
                "const byNumber = Object.fromEntries(report.cuentas.map(account => [account.numeroCuenta, account]));",
                "pm.test('Cuenta 225487 termina en 700', () => pm.expect(byNumber['225487'].saldoDisponible).to.eql(700));",
                "pm.test('Cuenta 496825 termina en 0', () => pm.expect(byNumber['496825'].saldoDisponible).to.eql(0));",
                "pm.test('Incluye depósito de 600', () => pm.expect(byNumber['225487'].movimientos.some(m => m.valor === 600)).to.be.true);",
                "pm.test('Incluye retiro de 540', () => pm.expect(byNumber['496825'].movimientos.some(m => m.valor === -540)).to.be.true);"
              ]
            }
          }]
        }
      ]
    }
