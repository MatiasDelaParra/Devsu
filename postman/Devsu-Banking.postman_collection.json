      "name": "1. Clientes",
      "item": [
        {
          "name": "Crear Jose Lema",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Jose Lema\",\n  \"genero\": \"Masculino\",\n  \"edad\": 35,\n  \"identificacion\": \"1710000001\",\n  \"direccion\": \"Otavalo sn y principal\",\n  \"telefono\": \"098254785\",\n  \"clienteId\": \"CLI-JOSE\",\n  \"contrasena\": \"1234\",\n  \"estado\": true\n}"
            },
            "url": "{{customerBaseUrl}}/api/clientes"
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Cliente Jose creado', () => pm.response.to.have.status(201));",
                "pm.test('La contraseña no se expone', () => pm.expect(pm.response.json()).not.to.have.property('contrasena'));"
